{
    "name": "var-expand-c",
    "aliases": {
        "linux": [
            ["list_vars", ["python", "{relative_root}/list_vars.py"]],
            [
                "list_vars_env", {
                    "cmd": ["python", "{relative_root}/list_vars.py"],
                    "environment": {
                        "set": {
                            "EXPAND_ALIAS_PRE": "-*-{EXPAND_C!e}-",
                            "EXPAND_C": "expand-c-alias",
                            "EXPAND_ALIAS_POST": "-*-{EXPAND_C!e}-",
                            "MERGE_C": "{MERGE_C!e},ALIAS"
                        }
                    }
                }
            ]
        ],
        "windows": [
            ["list_vars", ["python", "{relative_root}/list_vars.py"]],
            [
                "list_vars_env", {
                    "cmd": ["python", "{relative_root}/list_vars.py"],
                    "environment": {
                        "set": {
                            "EXPAND_ALIAS_PRE": "-*-{EXPAND_C!e}-",
                            "EXPAND_C": "expand-c-alias",
                            "EXPAND_ALIAS_POST": "-*-{EXPAND_C!e}-",
                            "MERGE_C": "{MERGE_C!e},ALIAS"
                        }
                    }
                }
            ]
        ]
    },
    "environment": {
        "os_specific": true,
        "*": {
            "NOT_OPERATION": "Incorrect, should be inside operation",
            "set": {
                "EXPAND_WILD_PRE": "-*-{EXPAND_C!e}-",
                "EXPAND_C": "expand-c-wild",
                "EXPAND_WILD_POST": "-*-{EXPAND_C!e}-",
                "MERGE_C": "WILD",
                "PY_EXPAND_WILD": "-not-e-*-{MERGE_C}-"
            }
        },
        "linux": {
            "set": {
                "EXPAND_LINUX_PRE": "-L-{EXPAND_C!e}-",
                "EXPAND_C": "expand-c-linux",
                "EXPAND_LINUX_POST": "-L-{EXPAND_C!e}-",
                "MERGE_C": "{MERGE_C!e},linux",
                "PY_EXPAND_LINUX": "-not-e-L-{MERGE_C}-"
            }
        },
        "windows": {
            "set": {
                "EXPAND_WINDOWS_PRE": "-W-{EXPAND_C!e}-",
                "EXPAND_C": "expand-c-windows",
                "EXPAND_WINDOWS_POST": "-W-{EXPAND_C!e}-",
                "MERGE_C": "{MERGE_C!e},windows",
                "PY_EXPAND_WINDOWS": "-not-e-W-{MERGE_C}-"
            }
        }
    }
}
